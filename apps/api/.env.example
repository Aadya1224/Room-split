# ─── Database ────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://roomsplit:roomsplit@localhost:5432/roomsplit_dev"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# CORS – must match your Vite dev server origin
CORS_ORIGIN=http://localhost:5173

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_AT_LEAST_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_AT_LEAST_32_CHARS
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_QUERIES=false

# ─── Scheduler ────────────────────────────────────────────────────────────────
DISABLE_SCHEDULER=false
